Rule 15    simbolo -> TERMINAL
Rule 16    simbolo -> NON_TERMINAL
Rule 17    token_section -> token_decl token_section
Rule 18    token_section -> <empty>
Rule 19    token_decl -> TERMINAL EQUALS REGEX newlines
Rule 20    token_decl -> TERMINAL EQUALS REGEX
Rule 21    newlines -> NEWLINE
Rule 22    newlines -> NEWLINE newlines

